{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "biome check src/",
    "lint:fix": "biome check src/ --write && oxlint --type-aware --fix",
    "format": "biome format src/ --write",
    "preview": "vite preview",
    "lint:types": "oxlint --type-aware",
    "lint:all": "biome check src/ && oxlint --type-aware"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "globals": "^15.11.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.22.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.3",
    "vite": "^8.0.10"
  }
}
